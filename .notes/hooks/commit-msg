#!/usr/bin/env bash
# .notes/hooks/commit-msg
#
# Enforces the commit-message anchor rule:
#   When a notes file is touched in this commit, the commit message body
#   must contain a line like:  Notes: 2026-05-22 — Short title
#
# Makes `git log --grep "Notes:"` a reliable handoff audit log.

set -euo pipefail

if [[ "${NOTES_SKIP:-}" == "1" ]]; then
  exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
# shellcheck disable=SC1091
source "$REPO_ROOT/.notes/config.sh"
[[ -f "$REPO_ROOT/.notesrc" ]] && source "$REPO_ROOT/.notesrc"

if [[ "$NOTES_REQUIRE_COMMIT_ANCHOR" != "1" ]] || [[ "$NOTES_MODE" == "off" ]]; then
  exit 0
fi

COMMIT_MSG_FILE="$1"

# Only enforce if a notes file is staged
STAGED=$(git diff --cached --name-only --diff-filter=ACMRT)
NEEDS_ANCHOR=0
while IFS= read -r file; do
  if [[ "$file" == "$NOTES_AI_FILE" || "$file" == "$NOTES_BACKEND_FILE" ]]; then
    NEEDS_ANCHOR=1
    break
  fi
done <<< "$STAGED"

[[ "$NEEDS_ANCHOR" == "0" ]] && exit 0

# Look for the anchor. Accept either em-dash, en-dash, or hyphen as separator.
# Strip comment lines (#) before checking.
ANCHOR_REGEX='^Notes:[[:space:]]+[0-9]{4}-[0-9]{2}-[0-9]{2}[[:space:]]+[—–-]'
if grep -v '^#' "$COMMIT_MSG_FILE" | grep -Eq "$ANCHOR_REGEX"; then
  exit 0
fi

echo ""
echo "═══════════════════════════════════════════════════════════════════════"
echo " Repo Handoff Notes v2 — missing commit-message anchor"
echo "═══════════════════════════════════════════════════════════════════════"
echo ""
echo " You touched a notes file but the commit message body has no anchor."
echo " Add a line like this to the commit body (NOT the subject):"
echo ""
echo "     Notes: $(date +%Y-%m-%d) — Short title matching the entry"
echo ""
echo " This makes \`git log --grep \"Notes:\"\` a complete audit trail."
echo ""
echo " Bypass with: NOTES_SKIP=1 git commit ..."
echo "═══════════════════════════════════════════════════════════════════════"

if [[ "$NOTES_MODE" == "warn" ]]; then
  echo "[notes] NOTES_MODE=warn — not failing"
  exit 0
fi

exit 1
